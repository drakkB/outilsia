{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OutilsIA Local Cockpit",
  "version": "0.1.1",
  "identifier": "fr.outilsia.localcockpit",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OutilsIA Local Cockpit",
        "width": 1180,
        "height": 780,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://outilsia.fr; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Diagnostic IA locale pour OutilsIA",
    "longDescription": "OutilsIA Local Cockpit scanne le PC, detecte Ollama et estime quels modeles IA locaux peuvent tourner sur la machine."
  }
}
